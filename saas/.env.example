# Purpose: Example configuration for the Docker-first SaaS build with demo fallback and live Tesla import.
# Input/Output: Copy to `.env` and adjust values before starting the stack.
# Invariants: `DEMO_MODE=true` keeps the safe fallback active when no live Tesla account is connected through the dashboard.
# Debug: If the app starts with unexpected defaults, compare the effective values with this file and the values shown in `/api/v1/me`.

APP_NAME=Tesla Invoice Automatic SaaS
APP_ENV=development
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
SECRET_KEY=tesla-invoice-demo-secret-change-me
DEMO_MODE=true

# Docker Compose overrides this to PostgreSQL. The SQLite fallback is useful for quick local experiments.
DATABASE_URL=sqlite:///./data/local_demo.db
DATA_DIR=/data
SYNC_INTERVAL_SECONDS=1800

DEFAULT_FROM_EMAIL=no-reply@tesla-invoice-demo.local
DEMO_USER_EMAIL=demo@feberdin.local

# SMTP is optional. If SMTP_HOST stays empty, test mails and sync summaries are written to `email-outbox.log` only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
