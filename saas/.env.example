# Purpose: Example configuration for the Docker-first SaaS build with demo fallback and live Tesla import.
# Input/Output: Copy to `.env` and adjust values before starting the stack.
# Invariants: `DEMO_MODE=true` keeps the safe fallback active when no live Tesla account is connected through the dashboard.
# Debug: If the app starts with unexpected defaults, compare the effective values with this file and the values shown in `/api/v1/me`.

APP_NAME=Tesla Invoice Automatic SaaS
APP_ENV=development
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
SECRET_KEY=tesla-invoice-demo-secret-change-me
DEMO_MODE=true

# Docker Compose overrides this to PostgreSQL. The SQLite fallback is useful for quick local experiments.
DATABASE_URL=sqlite:///./data/local_demo.db
DATA_DIR=/data
# Preferred operator-facing setting. When set above 0, this overrides `SYNC_INTERVAL_SECONDS`.
SYNC_INTERVAL_MINUTES=30
# Legacy fallback for environments that still prefer raw seconds.
SYNC_INTERVAL_SECONDS=1800

DEFAULT_FROM_EMAIL=no-reply@tesla-invoice-demo.local
DEMO_USER_EMAIL=demo@feberdin.local

# SMTP is optional. If SMTP_HOST stays empty, test mails and sync summaries are written to `email-outbox.log` only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Two Tesla connection variants can exist side by side:
# 1. Fleet OAuth for an official SaaS-style customer login
# 2. the unofficial owner-token import for self-hosted tests without Fleet billing
ENABLE_TESLA_FLEET_OAUTH=true
ENABLE_TESLA_OWNER_IMPORT=true

# Tesla Fleet OAuth for customer self-service login.
# Register the same callback URL in the Tesla Developer Portal that the app uses here.
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_FLEET_API_BASE_URL=https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_OAUTH_SCOPE=openid offline_access user_data vehicle_device_data vehicle_charging_cmds
TESLA_OAUTH_REDIRECT_PATH=/api/v1/tesla/oauth/callback
